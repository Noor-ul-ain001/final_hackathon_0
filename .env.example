# AI Employee Environment Configuration
# =======================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# EXECUTION MODE
# ===========================================
# production = real execution, development = safe mode
EXECUTION_MODE=production

# Set to true to simulate all actions without actually executing
DRY_RUN=false

# ===========================================
# VAULT CONFIGURATION
# ===========================================
VAULT_PATH=./AI_Employee_Vault

# ===========================================
# GMAIL / EMAIL CONFIGURATION
# ===========================================
# Gmail OAuth2 credentials (from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=./mcp/email-mcp/credentials.json
GMAIL_TOKEN_PATH=./mcp/email-mcp/token.json

# ===========================================
# XERO ACCOUNTING (Gold Tier)
# ===========================================
# Xero OAuth2 credentials — create an app at https://developer.xero.com/myapps/
# Choose "Web app" with scope: openid profile email accounting.transactions
#        accounting.contacts accounting.reports.read offline_access
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret

# Your Xero organisation/tenant ID (found after OAuth or via GET /connections)
XERO_TENANT_ID=your_xero_tenant_id

# Refresh token obtained from the one-time OAuth2 flow
# Run:  node -e "require('./mcp/xero-mcp/oauth_setup.js')"  to generate it
XERO_REFRESH_TOKEN=your_xero_refresh_token

# Enable Xero MCP integration
USE_XERO_MCP=true

# ===========================================
# ODOO ACCOUNTING (Gold Tier)
# ===========================================
# Odoo Community Edition connection
ODOO_URL=http://localhost:8069
ODOO_DB=ai_employee
ODOO_USERNAME=admin
ODOO_PASSWORD=your_odoo_password_here

# Enable Odoo integration
USE_ODOO_MCP=true

# ===========================================
# TWITTER / X (Gold Tier)
# ===========================================
# Twitter API v2 credentials (from developer.twitter.com)
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# Enable Twitter integration
USE_TWITTER_MCP=true

# ===========================================
# LINKEDIN
# ===========================================
# LinkedIn API credentials (OAuth2 access token)
# Get this from LinkedIn Developer Portal: https://www.linkedin.com/developers/
# Required scopes: openid, profile, w_member_social
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# Your LinkedIn Person ID (found in your profile URL or via API)
# This is required for posting. You can find it by:
# 1. Going to your LinkedIn profile URL (e.g., linkedin.com/in/yourname/)
# 2. Using the /v2/me API endpoint
LINKEDIN_PERSON_ID=your_linkedin_person_id
LINKEDIN_USER_ID=your_linkedin_user_id

# ===========================================
# FACEBOOK (Gold Tier)
# ===========================================
# Facebook Graph API credentials
# Get these from Meta for Developers: https://developers.facebook.com/
# Required permissions: pages_manage_posts, pages_read_engagement, pages_show_list
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id

# How to get Facebook credentials:
# 1. Go to https://developers.facebook.com/ and create an app
# 2. Add Facebook Login product
# 3. Generate access token with pages_manage_posts permission
# 4. Get your Page ID from your Facebook Page's About section
# 5. Token expires in 60 days - use long-lived tokens for production

# ===========================================
# INSTAGRAM (Gold Tier)
# ===========================================
# Instagram Graph API credentials (via Facebook Business)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id

# ===========================================
# WHATSAPP
# ===========================================
# WhatsApp Cloud API (from Meta Business)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_BUSINESS_ID=your_business_id

# WhatsApp watcher mode
WHATSAPP_USE_WEBHOOK=true
WHATSAPP_USE_PLAYWRIGHT=false
WHATSAPP_SESSION_PATH=./.whatsapp_session

# ===========================================
# CEO BRIEFING SCHEDULE
# ===========================================
# Day of week (0=Monday, 6=Sunday)
CEO_BRIEFING_DAY=6

# Time (24-hour format)
CEO_BRIEFING_HOUR=20
CEO_BRIEFING_MINUTE=0

# ===========================================
# FINANCE WATCHER
# ===========================================
# Plaid API for banking (optional)
USE_PLAID_API=false
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret

# Transaction alert thresholds
LARGE_TRANSACTION_THRESHOLD=500
UNUSUAL_PATTERN_THRESHOLD=200

# ===========================================
# WEB DASHBOARD
# ===========================================
DASHBOARD_PORT=5000
DASHBOARD_HOST=0.0.0.0

# ===========================================
# WEBHOOK SERVER
# ===========================================
WEBHOOK_PORT=5000

# ===========================================
# NOTIFICATION PREFERENCES
# ===========================================
# Enable/disable notification channels
NOTIFY_WHATSAPP=true
NOTIFY_EMAIL=true
NOTIFY_SLACK=false

# Slack (optional)
SLACK_WEBHOOK_URL=

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO
AUDIT_RETENTION_DAYS=90

# ===========================================
# SECURITY
# ===========================================
# Maximum actions per hour (rate limiting)
MAX_EMAILS_PER_HOUR=10
MAX_PAYMENTS_PER_HOUR=3
MAX_SOCIAL_POSTS_PER_HOUR=5

# Approval thresholds
PAYMENT_APPROVAL_THRESHOLD=100
AUTO_APPROVE_KNOWN_CONTACTS=false

# ===========================================
# RALPH WIGGUM LOOP
# ===========================================
# Check interval in seconds
RALPH_CHECK_INTERVAL=30

# Maximum iterations for a single task
RALPH_MAX_ITERATIONS=10

# Auto-execute steps (false = require approval for all)
RALPH_AUTO_EXECUTE=true
